{
  "mcpServers": {
    "pc-rig": {
      "command": "npx",
      "args": [
        "-y",
        "tsx",
        "{{PC_TRUNK_PATH}}/packages/mcp/src/server.ts"
      ],
      "env": {
        "PC_PROJECT_ID": "{{PROJECT_ID}}",
        "PC_PROJECT_SLUG": "{{PROJECT_SLUG}}",
        "PC_SERVER_PORT": "{{PC_SERVER_PORT}}"
      }
    },
    "webhook": {
      "command": "node",
      "args": [
        "{{PC_TRUNK_PATH}}/channel-server/server.js"
      ],
      "env": {
        "PC_PROJECT_ID": "{{PROJECT_ID}}",
        "PC_PROJECT_SLUG": "{{PROJECT_SLUG}}",
        "CHANNEL_PORT": "{{PC_CHANNEL_PORT}}"
      }
    }
  }
}
