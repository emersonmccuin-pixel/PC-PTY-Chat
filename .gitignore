node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo
out/
coverage/
apps/desktop/release/
apps/desktop/staging/

# Runtime state (transient)
data/*
!data/.gitkeep
apps/server/data/
*.db
*.db-*
*.sqlite
*.sqlite-*

# Manual / accidental data-dir snapshots (timestamped)
data.bak.*

# Worktrees managed by the runtime (regenerated)
worktrees/

# Dev fixture: workspace/ has its own embedded git repo (per-project shape).
# Default project templates will land under templates/ when the chassis work needs them.
workspace/

# Local agent/browser tool state
/.playwright-mcp/
/.mcp.json
/.claude/

# Playwright artifacts (regenerated per run)
test-results/
playwright-report/
tests/playwright/results.json
tests/playwright/snap-shell.png
tests/playwright/.tmp-*.spec.ts
tests/playwright/readme-*.spec.ts

# Logs and scratch files
*.log
*.log.*
*.jsonl
*.out
.tmp-*
.dev-logs/
report.*.json
*.tmp
*.tmp.*
*.bak
*.orig
.tr-deliverable.tmp.md
orch-patch.json
post-chat.yml
/E*Claude

